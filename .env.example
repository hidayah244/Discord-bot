# ======================================
# Discord Music Bot - Konfigurasi
# ======================================
# Salin file ini menjadi .env dan isi nilainya

# Token bot Discord (WAJIB)
# Dapatkan dari https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Prefix command (opsional, default: !)
PREFIX=!

# Spotify Client ID & Secret (OPSIONAL - untuk dukungan Spotify)
# Dapatkan dari https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ID channel voice untuk 24/7 stay (OPSIONAL)
# Bot akan otomatis join channel ini saat startup
# Kosongkan jika tidak mau auto-join
DEFAULT_VOICE_CHANNEL_ID=
